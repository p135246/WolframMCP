{
  "inputs": [],
  "servers": {
    "wolfram": {
      "command": ".venv/bin/python",
      "args": [
        "-m", "wolfram_mcp.server",
        "--transport", "stdio"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "WOLFRAM_KERNEL_PATH": "/Applications/Wolfram.app/Contents/MacOS/WolframKernel"
      }
    }
  }
}
